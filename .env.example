# Copy this file to .env and fill in your keys
# NEVER commit .env to git — it's in .gitignore

# ─── STAGE 1: Fal.ai (PAID/TRIAL — fastest & highest quality SDXL) ─────────────
# Get a key at: https://fal.ai/dashboard/keys (Requires $1 trial or credit card)
FAL_API_KEY=your_fal_key_here

# ─── PRIMARY: HuggingFace (FASTEST — free image-to-image AI) ──────────────────
# Get a free token at: https://huggingface.co/settings/tokens
# Click "New Token" → name it anything → Read access → Copy the hf_... key
HUGGINGFACE_API_KEYS=hf_your_key_here

# ─── FALLBACK 1: OpenRouter (free vision analysis) ────────────────────────────
# Get at: https://openrouter.ai → Settings → API Keys
OPENROUTER_API_KEY=

# ─── FALLBACK 2: Gemini direct keys (round-robin, may have quota limits) ──────
# Get at: https://aistudio.google.com/app/apikey
# Add multiple keys separated by commas, no spaces
GEMINI_API_KEYS=key1,key2,key3

# ─── UNUSED (reserved for future use) ─────────────────────────────────────────
OPENAI_API_KEY=
